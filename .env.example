# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- NomixClicker API ---
NOMIX_API_URL=https://panel.nomixclicker.com/clicker/v1
NOMIX_API_KEY=

# When true, all Nomix calls return canned data — useful before the dongle ships.
# Set to false (or remove) once you have hardware connected.
NOMIX_USE_MOCK=true

# --- Cron ---
# Shared secret between Vercel Cron and the /api/cron/* routes. Generate a
# strong random value (e.g. `openssl rand -hex 32`). Vercel injects it as
# `Authorization: Bearer $CRON_SECRET` on scheduled invocations.
CRON_SECRET=

# --- Telegram bridge ---
# Bot token from @BotFather. The dashboard uses this to forward uploaded
# videos to the iPhone via Telegram (no compression — sendDocument).
TELEGRAM_BOT_TOKEN=
# Numeric ID of the channel/chat the bot posts into. The iPhone's Telegram
# account must also be a member of this chat so it receives the files.
TELEGRAM_UPLOAD_CHAT_ID=
